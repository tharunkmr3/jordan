# LiveKit Cloud — the worker connects as an agent over wss://
# Values come from your LiveKit Cloud project Settings → Keys.
# URL format is wss://<project-subdomain>.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_secret_here

# Sarvam — single key used for STT (Saarika), LLM (Sarvam-M via OpenAI-
# compatible /v1), TTS (Bulbul v3). Same key the Next.js app uses.
SARVAM_API_KEY=your_sarvam_key_here

# Supabase — worker reads the agents table to resolve system_prompt,
# voice_id, language per call. Same project as the main app.
SUPABASE_URL=https://odtmtakcfslkyfyexdmm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Local dev note: the main Next.js app's .env.local is NOT read by this
# worker. Copy these values into voice-worker/.env (or export them in
# your shell) before running `npm run dev`.
#
# Prod note: add the same vars in Coolify under the voice-worker
# service's Environment Variables panel.
